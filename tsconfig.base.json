{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "paths": {
            "@game/shared/*": [
                "./shared/*"
            ],
            "@client/*": [
                "./client/src/*"
            ],
            "@server/*": [
                "./server/src/*"
            ]
        }
    }
}